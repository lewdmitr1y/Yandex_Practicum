  <diagram id="5hfhekeH1kYWlCb4wukP" name="DFD логические">
    <mxGraphModel dx="3018" dy="3322" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
